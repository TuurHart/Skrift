<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Group shared container — the app and the SkriftShare extension exchange
	     data through it (CaptureInbox). LITERAL value per config file: a build-setting
	     variable here broke automatic provisioning on the CLI (the profile matcher
	     could not resolve $(SKRIFT_APP_group.com.skrift.mobile), so no profile ever "matched"). -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.skrift.mobile</string>
	</array>
</dict>
</plist>
